import { useState, useEffect } from 'react'
import { supabase } from './supabaseClient'
import './App.css'
import Properties from './Properties'
import PropertyDetail from './PropertyDetail'

const TABLES = [
  { key: 'properties', label: 'العقارات' },
  { key: 'units', label: 'الوحدات' },
  { key: 'tenants', label: 'المستأجرون' },
  { key: 'leases', label: 'العقود' },
]

function App() {
  const [status, setStatus] = useState('loading')
  const [page, setPage] = useState('dashboard')
  const [counts, setCounts] = useState({})
  const [errorMsg, setErrorMsg] = useState('')

  async function fetchCount(table) {
    const { count, error } = await supabase
      .from(table)
      .select('*', { count: 'exact', head: true })

    if (error) throw new Error(`${table}: ${error.message}`)
    return count
  }

  async function runTest() {
    setStatus('loading')
    setErrorMsg('')
    try {
      const results = {}
      for (const t of TABLES) {
        results[t.key] = await fetchCount(t.key)
      }
      setCounts(results)
      setStatus('success')
    } catch (err) {
      setErrorMsg(err.message)
      setStatus('error')
    }
  }
  
  useEffect(() => {
    runTest()
  }, [])

if (page === 'properties') {
  return <Properties onBack={() => setPage('dashboard')} onSelectProperty={(id) => setPage('property-' + id)} />
}

if (page.startsWith('property-')) {
  const propertyId = page.replace('property-', '')
  return <PropertyDetail id={propertyId} onBack={() => setPage('properties')} />
}  
   } 
  return (
    <div dir="rtl" style={{ fontFamily: 'sans-serif', padding: '40px', maxWidth: '700px', margin: '0 auto' }}>
      <h1>مكتب ثامر بن سلمان العقاري</h1>
      <p style={{ color: '#666' }}>لوحة تحكم — اختبار الاتصال بقاعدة البيانات</p>

      <button onClick={runTest} style={{ padding: '10px 20px', marginBottom: '20px', cursor: 'pointer' }}>
        تحديث
      </button>

      {status === 'loading' && <p>جاري الاتصال...</p>}
      {status === 'error' && (
        <div style={{ background: '#fee', padding: '15px', borderRadius: '8px', color: '#c00' }}>
          فشل الاتصال: {errorMsg}
        </div>
      )}
      {status === 'success' && (
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '15px' }}>
          {TABLES.map(({ key, label }) => (
     <div
              key={key}
              onClick={() => key === 'properties' && setPage('properties')}
              style={{
                background: '#f5f5f5',
                padding: '20px',
                borderRadius: '8px',
                cursor: key === 'properties' ? 'pointer' : 'default',
              }}
            >       
              <div style={{ color: '#666', marginBottom: '8px' }}>{label}</div>
              <div style={{ fontSize: '28px', fontWeight: 'bold' }}>{counts[key] ?? 0}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  )
}

export default App